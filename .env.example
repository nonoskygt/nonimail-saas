# ===== NoniMail SaaS — variables de entorno =====
# Copiar a .env y rellenar. NUNCA commitear .env.

PORT=8780
PUBLIC_URL=http://localhost:8780

# Clave para firmar JWT (cambiar por algo largo y aleatorio)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Clave AES-256 (hex de 64 chars = 32 bytes) para cifrar tokens OAuth/credenciales IMAP en reposo.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ===== LLM (clasificación de ruido) =====
# Local con Ollama. Para producción multiusuario podés apuntar a un servidor con vLLM/Open-WebUI.
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen3:8b

# ===== Dominios siempre protegidos (nunca se borran) =====
# Lista separada por comas. Poné tu propio dominio y los de tus bancos/proveedores clave.
# Ej: PROTECT_DOMAINS=miempresa.com,mibanco.com,proveedor.com
PROTECT_DOMAINS=

# ===== Gmail (Google Cloud OAuth 2.0) =====
# Crear proyecto en https://console.cloud.google.com -> APIs & Services -> Credentials
# Tipo: OAuth client ID -> Web application. Habilitar Gmail API.
# Redirect URI: ${PUBLIC_URL}/api/connect/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Outlook / Microsoft 365 (Azure AD / Entra ID) =====
# Registrar app en https://entra.microsoft.com -> App registrations
# Permisos Microsoft Graph (delegated): Mail.ReadWrite, Mail.Send, User.Read, offline_access
# Redirect URI: ${PUBLIC_URL}/api/connect/outlook/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# common = cuentas personales + organizacionales; o un tenant id específico
MS_TENANT=common

# ===== IMAP =====
# No requiere credenciales globales: cada usuario conecta su buzón con host/puerto/usuario/contraseña.
